# Local secrets / credentials
.env
.env.*
!.env.example
*.pem
*.key
secrets/
~/.config/orbit-skills/

# Bundled scanner binaries (downloaded by setup)
_tools/

# Caches
_cache/
__pycache__/
*.pyc
node_modules/
.venv/
venv/

# Clone workdir (skill source lives here pre-acceptance; only vetted survivors get copied into <track>/)
candidates/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Logs that are too noisy to track (keep curated logs only)
_logs/run/*.log

# Raw scanner output contains apparent-secret strings (even when they're
# false-positive matches like docstring examples or model identifiers).
# GitHub's secret-scanning push protection blocks these. Keep them local
# only — the sanitised audit.json is the public audit trail.
_logs/scan/**/gitleaks.json
_logs/scan/**/gitleaks.stdout.txt
_logs/scan/**/trufflehog.json
_logs/scan/**/osv.json
_logs/scan/**/pip-audit.json
_logs/scan/**/semgrep.json
_logs/scan/**/semgrep.stdout.txt
